{
  "session": {
    "projects": ["$DEVROOT/wsp/*", "$DEVROOT/code/projects/*", "$DEVROOT/code/experiments/*", "$DEVROOT/code/archived/*", "$DEVROOT/infra/*"],
    "ignore_dir": ["~/downloads", "~/Downloads"]
  },
  "lsp": {
    "jdtls": {
      "runtimes": [
        { "name": "JavaSE-1.8", "path": "/etc/jdk/zulu8" },
        { "name": "JavaSE-21", "path": "/etc/jdk/zulu21", "default": true },
        { "name": "JavaSE-25", "path": "/etc/jdk/zulu25" }
      ],
      "maven": {
        "globalSettings": "~/.m2/settings.xml"
      }
    }
  }
}
